# Raspberry Pi LAN IP (used by HA to reach other services)
PI_HOST_IP=192.168.1.210

# Home Assistant
HA_TOKEN=your_long_lived_access_token_here

# MQTT Broker (Docker DNS name for bridge network services)
MQTT_BROKER=mosquitto
MQTT_PORT=1883

# ChromaDB (Docker DNS name for bridge network services)
CHROMADB_HOST=chromadb
CHROMADB_PORT=8000

# OpenAI (used by LangGraph agents)
OPENAI_API_KEY=your_openai_api_key_here

# Home Assistant REST API
HA_BASE_URL=http://homeassistant:8123

# Graph pattern: "supervisor" or "flat"
GRAPH_PATTERN=supervisor
